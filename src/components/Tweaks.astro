<button class="tweaks-fab" data-tweaks-toggle aria-label="Open tweaks" title="Tweaks">
  <svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
    <circle cx="12" cy="12" r="3" />
    <path d="M19.4 15a1.7 1.7 0 0 0 .3 1.8l.1.1a2 2 0 1 1-2.8 2.8l-.1-.1a1.7 1.7 0 0 0-1.8-.3 1.7 1.7 0 0 0-1 1.5V21a2 2 0 1 1-4 0v-.1a1.7 1.7 0 0 0-1.1-1.5 1.7 1.7 0 0 0-1.8.3l-.1.1a2 2 0 1 1-2.8-2.8l.1-.1a1.7 1.7 0 0 0 .3-1.8 1.7 1.7 0 0 0-1.5-1H3a2 2 0 1 1 0-4h.1a1.7 1.7 0 0 0 1.5-1.1 1.7 1.7 0 0 0-.3-1.8l-.1-.1a2 2 0 1 1 2.8-2.8l.1.1a1.7 1.7 0 0 0 1.8.3H9a1.7 1.7 0 0 0 1-1.5V3a2 2 0 1 1 4 0v.1a1.7 1.7 0 0 0 1 1.5 1.7 1.7 0 0 0 1.8-.3l.1-.1a2 2 0 1 1 2.8 2.8l-.1.1a1.7 1.7 0 0 0-.3 1.8V9a1.7 1.7 0 0 0 1.5 1H21a2 2 0 1 1 0 4h-.1a1.7 1.7 0 0 0-1.5 1z" />
  </svg>
</button>

<div class="tweaks" data-tweaks-panel>
  <div class="tweaks-head">
    <strong>Tweaks</strong>
    <button class="tweaks-close" data-tweaks-toggle aria-label="Close">×</button>
  </div>
  <h4>Theme</h4>
  <div class="tweak-row" data-tweak-group="theme">
    <button data-value="light">light</button>
    <button data-value="dark">dark</button>
    <button data-value="sepia">sepia</button>
  </div>
  <h4>Aesthetic</h4>
  <div class="tweak-row" data-tweak-group="aesthetic">
    <button data-value="index">Index</button>
    <button data-value="studio">Studio</button>
    <button data-value="journal">Journal</button>
  </div>
</div>

<script>
  const root = document.documentElement;
  const panel = document.querySelector<HTMLElement>("[data-tweaks-panel]");
  const toggles = document.querySelectorAll<HTMLButtonElement>("[data-tweaks-toggle]");

  const getStored = (k: string, fallback: string) => {
    try { return localStorage.getItem("tweak:" + k) ?? fallback; } catch { return fallback; }
  };
  const setStored = (k: string, v: string) => {
    try { localStorage.setItem("tweak:" + k, v); } catch {}
  };

  const state = {
    theme: getStored("theme", root.dataset.theme || "light"),
    aesthetic: getStored("aesthetic", root.dataset.aesthetic || "journal"),
  };

  function apply() {
    root.dataset.theme = state.theme;
    root.dataset.aesthetic = state.aesthetic;
    document.querySelectorAll<HTMLElement>("[data-tweak-group]").forEach(group => {
      const key = group.dataset.tweakGroup as "theme" | "aesthetic";
      group.querySelectorAll<HTMLButtonElement>("button").forEach(btn => {
        btn.classList.toggle("on", btn.dataset.value === state[key]);
      });
    });
  }
  apply();

  toggles.forEach(btn => btn.addEventListener("click", () => panel?.classList.toggle("on")));

  document.querySelectorAll<HTMLElement>("[data-tweak-group]").forEach(group => {
    const key = group.dataset.tweakGroup as "theme" | "aesthetic";
    group.querySelectorAll<HTMLButtonElement>("button").forEach(btn => {
      btn.addEventListener("click", () => {
        const v = btn.dataset.value!;
        state[key] = v;
        setStored(key, v);
        apply();
      });
    });
  });
</script>

<script is:inline>
  (function () {
    if (window.__cursorParallaxInit) return;
    window.__cursorParallaxInit = true;
    if (window.matchMedia && window.matchMedia("(prefers-reduced-motion: reduce)").matches) return;

    let tx = 0, ty = 0, cx = 0, cy = 0, raf = null;
    const root = document.documentElement;

    function loop() {
      cx += (tx - cx) * 0.08;
      cy += (ty - cy) * 0.08;
      root.style.setProperty("--mx", cx.toFixed(4));
      root.style.setProperty("--my", cy.toFixed(4));
      root.style.setProperty("--mpx", (50 + cx * 50).toFixed(2) + "%");
      root.style.setProperty("--mpy", (50 + cy * 50).toFixed(2) + "%");
      if (Math.abs(tx - cx) > 0.001 || Math.abs(ty - cy) > 0.001) {
        raf = requestAnimationFrame(loop);
      } else {
        raf = null;
      }
    }
    function kick() { if (raf == null) raf = requestAnimationFrame(loop); }

    window.addEventListener("pointermove", (e) => {
      tx = (e.clientX / window.innerWidth) * 2 - 1;
      ty = (e.clientY / window.innerHeight) * 2 - 1;
      kick();
    }, { passive: true });
    window.addEventListener("pointerleave", () => { tx = 0; ty = 0; kick(); });
  })();
</script>

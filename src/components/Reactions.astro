---
interface Props {
  articleId: string;
  /** If true, render inline in the document flow instead of fixed to the viewport. */
  inline?: boolean;
}
const { articleId, inline = false } = Astro.props;

/**
 * Multi-colour pixel-art reaction icons. Each cell is a 2×2 unit rect on
 * a 16×16 viewBox with `shape-rendering="crispEdges"` so browsers keep
 * the pixels blocky. Each icon layers a main colour plus a second accent
 * colour (shadow, highlight, or feature detail). Keys kept intact
 * (thoughtful/relatable/good/loved/mind) so existing KV counts persist.
 */
const reactions = [
  {
    key: "thoughtful",
    label: "True",
    // Green check — emerald body + lime highlight along the up-stroke
    icon: `<svg viewBox="0 0 16 16" width="16" height="16" shape-rendering="crispEdges">
      <g fill="#059669">
        <rect x="0" y="4" width="2" height="2"/>
        <rect x="0" y="6" width="4" height="2"/>
        <rect x="2" y="8" width="6" height="2"/>
        <rect x="4" y="10" width="4" height="2"/>
      </g>
      <g fill="#34D399">
        <rect x="14" y="0" width="2" height="2"/>
        <rect x="12" y="2" width="4" height="2"/>
        <rect x="10" y="4" width="4" height="2"/>
        <rect x="8" y="6" width="4" height="2"/>
        <rect x="6" y="8" width="4" height="2"/>
      </g>
    </svg>`,
  },
  {
    key: "relatable",
    label: "Felt that",
    // Yellow pixel face — yellow body + black eyes/mouth + pink cheeks
    icon: `<svg viewBox="0 0 16 16" width="16" height="16" shape-rendering="crispEdges">
      <g fill="#FBBF24">
        <rect x="4" y="0" width="8" height="2"/>
        <rect x="2" y="2" width="12" height="2"/>
        <rect x="0" y="4" width="16" height="8"/>
        <rect x="2" y="12" width="12" height="2"/>
        <rect x="4" y="14" width="8" height="2"/>
      </g>
      <g fill="#1F2937">
        <rect x="4" y="6" width="2" height="2"/>
        <rect x="10" y="6" width="2" height="2"/>
        <rect x="4" y="10" width="8" height="2"/>
      </g>
      <g fill="#F472B6">
        <rect x="2" y="8" width="2" height="2"/>
        <rect x="12" y="8" width="2" height="2"/>
      </g>
    </svg>`,
  },
  {
    key: "good",
    label: "Sharing this",
    // Paper plane — blue body + lighter cyan on the fold-line
    icon: `<svg viewBox="0 0 16 16" width="16" height="16" shape-rendering="crispEdges">
      <g fill="#2563EB">
        <rect x="12" y="0" width="4" height="2"/>
        <rect x="10" y="2" width="6" height="2"/>
        <rect x="8" y="4" width="6" height="2"/>
        <rect x="6" y="6" width="6" height="2"/>
        <rect x="0" y="8" width="12" height="2"/>
        <rect x="0" y="10" width="2" height="2"/>
        <rect x="8" y="10" width="2" height="2"/>
        <rect x="8" y="12" width="2" height="2"/>
      </g>
      <g fill="#7DD3FC">
        <rect x="14" y="2" width="2" height="2"/>
        <rect x="12" y="4" width="2" height="2"/>
        <rect x="10" y="6" width="2" height="2"/>
      </g>
    </svg>`,
  },
  {
    key: "loved",
    label: "Worth it",
    // Pixel star — gold body + orange shadow on the lower half
    icon: `<svg viewBox="0 0 16 16" width="16" height="16" shape-rendering="crispEdges">
      <g fill="#FBBF24">
        <rect x="6" y="0" width="4" height="2"/>
        <rect x="6" y="2" width="4" height="2"/>
        <rect x="0" y="4" width="16" height="2"/>
        <rect x="2" y="6" width="12" height="2"/>
        <rect x="4" y="8" width="8" height="2"/>
      </g>
      <g fill="#D97706">
        <rect x="2" y="10" width="4" height="2"/>
        <rect x="10" y="10" width="4" height="2"/>
        <rect x="0" y="12" width="4" height="2"/>
        <rect x="12" y="12" width="4" height="2"/>
        <rect x="0" y="14" width="2" height="2"/>
        <rect x="14" y="14" width="2" height="2"/>
      </g>
    </svg>`,
  },
  {
    key: "mind",
    label: "Bookmarked",
    // Pixel bookmark — purple ribbon body + coral accent on the notch
    icon: `<svg viewBox="0 0 16 16" width="16" height="16" shape-rendering="crispEdges">
      <g fill="#7C3AED">
        <rect x="4" y="0" width="8" height="2"/>
        <rect x="4" y="2" width="8" height="2"/>
        <rect x="4" y="4" width="8" height="2"/>
        <rect x="4" y="6" width="8" height="2"/>
        <rect x="4" y="8" width="8" height="2"/>
        <rect x="4" y="10" width="2" height="2"/>
        <rect x="10" y="10" width="2" height="2"/>
        <rect x="4" y="12" width="2" height="2"/>
        <rect x="10" y="12" width="2" height="2"/>
      </g>
      <g fill="#F87171">
        <rect x="6" y="12" width="4" height="2"/>
        <rect x="4" y="14" width="2" height="2"/>
        <rect x="10" y="14" width="2" height="2"/>
      </g>
    </svg>`,
  },
];
---

<div
  class={`reactions-bar ${inline ? "reactions-bar--inline" : ""}`}
  data-article-id={articleId}
  role="group"
  aria-label="Reactions"
>
  {reactions.map((r) => (
    <button class="reaction" data-key={r.key} aria-label={r.label} type="button">
      <span class="reaction-emoji" aria-hidden="true" set:html={r.icon}></span>
      <span class="reaction-label">{r.label}</span>
      <span class="reaction-count" hidden>0</span>
    </button>
  ))}
</div>

<script>
  type Counts = Record<string, number>;
  const emptyCounts = (): Counts => ({
    thoughtful: 0, relatable: 0, good: 0, loved: 0, mind: 0,
  });

  document.querySelectorAll<HTMLElement>(".reactions-bar").forEach((bar) => {
    const articleId = bar.dataset.articleId!;
    const storageKey = `reactions:${articleId}`;
    const apiUrl = `/api/reactions/${articleId}`;

    const loadLocal = (): Counts => {
      try {
        return { ...emptyCounts(), ...JSON.parse(localStorage.getItem(storageKey) || "{}") };
      } catch { return emptyCounts(); }
    };
    const saveLocal = (c: Counts) => {
      try { localStorage.setItem(storageKey, JSON.stringify(c)); } catch {}
    };

    let counts = loadLocal();
    const buttons = bar.querySelectorAll<HTMLButtonElement>(".reaction");

    const render = () => {
      buttons.forEach((btn) => {
        const k = btn.dataset.key!;
        const n = counts[k] || 0;
        const countEl = btn.querySelector<HTMLElement>(".reaction-count")!;
        if (n > 0) { countEl.hidden = false; countEl.textContent = String(n); }
        else { countEl.hidden = true; }
        btn.classList.toggle("has-count", n > 0);
      });
    };
    render();

    // Hydrate from server. If it fails (no API, offline, dev without wrangler),
    // we silently keep the localStorage values.
    fetch(apiUrl, { headers: { accept: "application/json" } })
      .then((r) => (r.ok ? r.json() : null))
      .then((server) => {
        if (server && typeof server === "object") {
          counts = { ...emptyCounts(), ...(server as Counts) };
          saveLocal(counts);
          render();
        }
      })
      .catch(() => { /* localStorage is good enough offline */ });

    buttons.forEach((btn) => {
      btn.addEventListener("click", () => {
        const k = btn.dataset.key!;

        // Optimistic UI: update immediately, don't wait for the network.
        counts[k] = (counts[k] || 0) + 1;
        saveLocal(counts);
        render();
        btn.classList.remove("bump");
        void btn.offsetWidth;
        btn.classList.add("bump");

        // Send to server. On success, reconcile with the authoritative count.
        // On failure, keep the optimistic value (user still sees their click).
        fetch(apiUrl, {
          method: "POST",
          headers: { "content-type": "application/json" },
          body: JSON.stringify({ key: k }),
        })
          .then((r) => (r.ok ? r.json() : null))
          .then((server) => {
            if (server && typeof server === "object") {
              counts = { ...emptyCounts(), ...(server as Counts) };
              saveLocal(counts);
              render();
            }
          })
          .catch(() => { /* keep optimistic value */ });
      });
    });
  });
</script>

<style>
  .reactions-bar {
    position: fixed;
    bottom: 24px;
    left: 50%;
    transform: translateX(-50%);
    z-index: 40;
    background: var(--bg-panel);
    border: 1px solid var(--rule);
    border-radius: 999px;
    padding: 8px 10px;
    display: flex;
    gap: 4px;
    box-shadow:
      0 16px 40px -16px rgba(15, 15, 16, 0.22),
      0 4px 12px -6px rgba(15, 15, 16, 0.12);
    max-width: calc(100vw - 32px);
    animation: reactions-rise 0.5s cubic-bezier(.2,.7,.2,1) both;
    animation-delay: 0.4s;
  }

  /* Inline variant: render statically in document flow. Used on /how-i-work. */
  .reactions-bar--inline {
    position: static;
    left: auto;
    bottom: auto;
    transform: none;
    margin: 0 auto;
    animation: none;
  }

  @keyframes reactions-rise {
    from { opacity: 0; transform: translate(-50%, 12px); }
    to   { opacity: 1; transform: translate(-50%, 0); }
  }

  .reaction {
    position: relative;
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 10px 16px;
    border-radius: 999px;
    background: transparent;
    border: 0;
    cursor: pointer;
    font-family: var(--mono);
    font-size: 11px;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--fg);
    white-space: nowrap;
    transition: background 0.18s, transform 0.12s;
  }
  .reaction:hover { background: var(--bg-soft); }
  .reaction:active { transform: scale(0.96); }
  .reaction:focus-visible {
    outline: 2px solid var(--accent);
    outline-offset: 2px;
  }

  .reaction-emoji {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 16px;
    height: 16px;
    line-height: 1;
    transform-origin: 50% 50%;
    color: currentColor;
    will-change: transform;
  }
  .reaction-emoji svg { display: block; image-rendering: pixelated; }
  .reaction-label {
    font-family: "Atkinson Hyperlegible", system-ui, sans-serif;
    font-size: 10px;
    font-weight: 700;
    letter-spacing: 0.08em;
  }
  .reaction-count {
    color: var(--fg-muted);
    font-weight: 600;
    margin-left: 2px;
    font-variant-numeric: tabular-nums;
  }
  .reaction.has-count { background: var(--bg-soft); }

  .reaction.bump .reaction-emoji {
    animation: reaction-bump 0.7s cubic-bezier(.2,.7,.2,1);
  }
  /* Keyframes tuned for maximum "click-me-again" feel: a fast squish,
     then an oversized pop (~3.2×), then a few rebounds that settle. */
  @keyframes reaction-bump {
    0%   { transform: scale(1)    rotate(0deg); }
    8%   { transform: scale(0.82) rotate(-8deg); }
    22%  { transform: scale(3.2)  rotate(-18deg); }
    38%  { transform: scale(0.7)  rotate(14deg); }
    55%  { transform: scale(1.8)  rotate(-8deg); }
    70%  { transform: scale(0.9)  rotate(5deg); }
    85%  { transform: scale(1.2)  rotate(-2deg); }
    100% { transform: scale(1)    rotate(0deg); }
  }

  /* Floating "+1" that rises and fades on click — bigger and louder now */
  .reaction::after {
    content: "+1";
    position: absolute;
    top: 4px;
    left: 50%;
    transform: translate(-50%, 0) scale(0.6);
    font-family: var(--mono);
    font-size: 15px;
    font-weight: 700;
    letter-spacing: 0;
    color: var(--accent);
    text-shadow: 0 1px 2px rgba(15, 15, 16, 0.12);
    opacity: 0;
    pointer-events: none;
  }
  .reaction.bump::after {
    animation: reaction-plus 1s cubic-bezier(.2,.7,.2,1);
  }
  @keyframes reaction-plus {
    0%   { opacity: 0; transform: translate(-50%, 0)    scale(0.6); }
    18%  { opacity: 1; transform: translate(-50%, -14px) scale(1.35); }
    60%  { opacity: 1; transform: translate(-50%, -38px) scale(1.15); }
    100% { opacity: 0; transform: translate(-50%, -58px) scale(1.4); }
  }

  @media (max-width: 640px) {
    .reaction-label { display: none; }
    .reaction { padding: 10px 12px; gap: 6px; }
  }

  @media (prefers-reduced-motion: reduce) {
    .reactions-bar { animation: none; }
    .reaction.bump .reaction-emoji { animation: none; }
  }
</style>

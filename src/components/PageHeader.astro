---
interface MetaItem { label: string; value: string; }
interface Props {
  eyebrow?: string;
  title: string;
  lede?: string;
  meta?: MetaItem[];
}
const { eyebrow, title, lede, meta } = Astro.props;
---

<header class="page-header">
  {eyebrow && <span class="section-eyebrow">{eyebrow}</span>}
  <h1 class="page-title" set:html={title} />
  {lede && <p class="section-lede">{lede}</p>}
  {meta && meta.length > 0 && (
    <div class="page-meta">
      {meta.map((m) => (
        <div>
          <span>{m.label}</span>
          <strong>{m.value}</strong>
        </div>
      ))}
    </div>
  )}
</header>

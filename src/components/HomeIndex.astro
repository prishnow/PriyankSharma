---
const pages = [
  { num: "01", label: "Notes", href: "/notes", blurb: "Writing on design leadership, AI experiments, and healthcare." },
  { num: "02", label: "Manual", href: "/about", blurb: "The long version — how I lead, how I got here, what I'm still figuring out." },
  { num: "03", label: "Work", href: "/work", blurb: "A partial résumé. The NDA shelf is taller." },
  { num: "04", label: "Reading", href: "#", blurb: "Books on the nightstand, in rotation, and the one I keep pretending to finish." },
  { num: "05", label: "Stuff", href: "#", blurb: "Leftovers, half-thoughts, and receipts from the week." },
];
---

<section class="section" id="index">
  <div class="section-head">
    <span class="section-eyebrow">Contents</span>
    <h2 class="section-title">Five <em>small notebooks</em>, one desk.</h2>
    <p class="section-lede">Pick whichever looks least intimidating today.</p>
  </div>
  <div class="container">
    <div class="home-index">
      {pages.map((p) => (
        <a class="home-index-row" href={p.href}>
          <span class="home-index-num">{p.num}</span>
          <h3 class="home-index-label">{p.label}</h3>
          <p class="home-index-blurb">{p.blurb}</p>
          <span class="home-index-arrow">→</span>
        </a>
      ))}
    </div>
  </div>
</section>

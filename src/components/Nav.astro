---
interface Props {
  page?: "home" | "thinking" | "doing" | "work" | "kit" | "about" | "colophon" | "how-i-work" | "notes";
}
const { page = "home" } = Astro.props;

const links: [string, string, string][] = [
  ["thinking", "Thinking", "/thinking"],
  ["doing",    "Doing",    "/doing"],
  ["work",     "Work",     "/work"],
  ["about",    "About",    "/about"],
  ["kit",      "Kit",      "/kit"],
];
---

<nav class="nav" data-nav>
  <div class="nav-inner">
    <a href="/" class="brand">Priyank Sharma</a>
    <div class="nav-links">
      {links.map(([id, label, href]) => (
        <a href={href} class={page === id ? "active" : ""}>{label}</a>
      ))}
    </div>
  </div>
</nav>

<script>
  const nav = document.querySelector<HTMLElement>("[data-nav]");
  if (nav) {
    const on = () => nav.classList.toggle("scrolled", window.scrollY > 10);
    window.addEventListener("scroll", on, { passive: true });
    on();
  }
</script>

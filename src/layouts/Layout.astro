---
import "../styles/global.css";
import Nav from "../components/Nav.astro";
import Footer from "../components/Footer.astro";
import Tweaks from "../components/Tweaks.astro";
import CursorParallax from "../components/CursorParallax.astro";

interface Props {
  title?: string;
  page?: "home" | "notes" | "manual" | "work" | "reading" | "stuff" | "about";
}
const { title = "Priyank Sharma — Portfolio", page = "home" } = Astro.props;
---

<!doctype html>
<html lang="en" data-theme="light" data-aesthetic="journal">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />
    <meta name="generator" content={Astro.generator} />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Fraunces:ital,opsz,wght@0,9..144,300..700;1,9..144,300..700&family=Instrument+Serif:ital@0;1&family=Plus+Jakarta+Sans:wght@400;500;600;700&family=Lora:ital,wght@0,400..700;1,400..700&family=JetBrains+Mono:wght@400;500&display=swap"
      rel="stylesheet"
    />
    <link
      href="https://api.fontshare.com/v2/css?f[]=general-sans@200,201,300,301,400,401,500,501,600,601,700,701,1,2&display=swap"
      rel="stylesheet"
    />

    <script is:inline>
      // Restore persisted theme/aesthetic before paint to avoid FOUC
      try {
        const t = localStorage.getItem("tweak:theme");
        const a = localStorage.getItem("tweak:aesthetic");
        if (t) document.documentElement.dataset.theme = t;
        if (a) document.documentElement.dataset.aesthetic = a;
      } catch {}
    </script>
  </head>
  <body>
    <Nav page={page} />
    <slot />
    <Footer />
    <Tweaks />
    <CursorParallax />
  </body>
</html>
